         }
+        case ENTRY_RELOC:
+        {
+            expectToken(parser, '[');
+            std::vector<uint8_t> rbytes;
+            char tok = getToken(parser);
+            while (tok != ']') {
+                if (tok != TOKEN_NUMBER)
+                    parse_error(parser, "invalid token: %c\n", tok);
+
+                rbytes.push_back((uint8_t) parser.i);
+                tok = expectToken2(parser, ',', ']');
+                if (tok == ',')
+                    tok = getToken(parser);
+            }
+            entry.length = rbytes.size();
+            entry.bytes  = dupBytes(rbytes);
+
+            expectToken(parser, ',');
+            expectToken(parser, TOKEN_STRING);
+            if (strcmp(parser.s, "addr") != 0)
+                parse_error(parser, "expected \"addr\", found \"%s\"\n", parser.s);
+            expectToken(parser, ':');
+
+            tok = expectToken2(parser, TOKEN_NUMBER, TOKEN_STRING);
+            if (tok == TOKEN_NUMBER)
+                entry.orig_addr = (intptr_t) parser.i;
+            else
+                entry.orig_addr = stringToNumber(parser);
+
+            break;
+        }
 
         default:
             break;
